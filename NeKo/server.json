{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.marcorusc/NeKo",
  "title": "NeKo Biological Network Builder",
  "description": "MCP server for biological network construction and analysis using pathway databases",
  "repository": {
    "url": "https://github.com/marcorusc/mcp-biomodelling-servers",
    "source": "github",
    "subfolder": "NeKo"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "mcp-biomodelling-servers",
      "version": "1.0.0",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "named",     "name": "--from", "value": "mcp-biomodelling-servers" },
        { "type": "positional", "value": "mcp-neko-server" }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}